# PACTA Backend — Environment Variables
# Copy this file to .env and update with your configuration

# ============================================
# FastAPI Configuration
# ============================================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production-generate-with-secrets.token_urlsafe
ALGORITHM=HS256

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql+asyncpg://pacta:pacta_dev_password@localhost:5432/pacta
# For testing (SQLite in-memory):
# DATABASE_URL=sqlite+aiosqlite:///:memory:

# ============================================
# JWT Configuration
# ============================================
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_EXPIRY_SECONDS=3600

# ============================================
# MinIO/S3 Configuration
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_password
MINIO_BUCKET=pacta-documents
MINIO_SECURE=false
# For AWS S3:
# AWS_S3_BUCKET=pacta-documents
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5000","http://localhost:8080"]

# ============================================
# Email Configuration (optional, for future notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@pacta.com

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# APScheduler Configuration (Background Jobs)
# ============================================
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_POOL_SIZE=5
